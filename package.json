{
  "name": "consultancy-app-root",
  "version": "1.0.0",
  "description": "Root package to run both frontend and backend easily",
  "scripts": {
    "install:all": "cd frontend && npm install",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && .\\venv\\Scripts\\activate && python manage.py runserver 0.0.0.0:8000",
    "dev": "npm run dev:frontend"
  }
}
